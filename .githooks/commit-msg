#!/usr/bin/env bash

# Commit-msg hook for Lista-de-Chamada-Web
# Enforce version token in commit body using single quotes, e.g. 'v.005.00-00x'

COMMIT_MSG_FILE="$1"
if [ -z "$COMMIT_MSG_FILE" ]; then
  echo "commit-msg hook requires the commit message file path."
  exit 1
fi

if ! grep -qE "'v\.[0-9]{3}\.[0-9]{2}-[0-9]{2}[0-9A-Za-z]*'" "$COMMIT_MSG_FILE"; then
  echo ""
  echo "ERROR: Commit message body must include the version token in single quotes."
  echo "Example: 'v.005.00-00a'"
  echo ""
  echo "Please add a version string in the body of the commit message." 
  echo "The version must match the pattern: 'v.005.00-00x'"
  echo ""
  exit 1
fi

exit 0
