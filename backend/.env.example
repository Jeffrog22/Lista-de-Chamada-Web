# Segurança
SECRET_KEY=sua_chave_secreta_desenvolvimento

# Identidade do ambiente (obrigatório para bloquear login fora da unidade)
ENV_NAME=lista-de-chamada-web
UNIT_NAME=Bela Vista

# Banco de dados (produção com Supabase)
# Exemplo Supabase (Session Pooler):
# DATABASE_URL=postgresql://postgres.xxxxx:[SUA_SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./dev.db

# CORS (separe múltiplas origens por vírgula)
# Em produção: URL do frontend Vercel
CORS_ORIGINS=http://localhost:5173
# Opcional: regex para previews/staging (Vercel + Netlify)
CORS_ORIGIN_REGEX=^https://.*\.(vercel\.app|netlify\.app)$

# API de clima (real)
# Preencha com os dados da sua conta/provedor.
CLIMATEMPO_TOKEN=seu_token_aqui
CLIMATEMPO_BASE_URL=https://api.climatempo.com.br/endpoint
CLIMATEMPO_LAT=-23.049194
CLIMATEMPO_LON=-47.007278
